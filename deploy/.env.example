# ─── Personal Chess Analyzer — Environment Variables ──────────────────────────
# Copy this file to deploy/.env and fill in your values.
# All variables have sensible defaults in docker-compose.yml.

# Image tag to use (set by CI, default: latest)
TAG=latest

# Node environment
NODE_ENV=production

# ── Ports (host-side bindings) ────────────────────────────────────────────────
FRONTEND_PORT=3000
API_PORT=8080
REDIS_HOST_PORT=6379      # set to "" to disable external exposure in prod
MONGO_HOST_PORT=27017     # set to "" to disable external exposure in prod

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8080

# ── API Gateway ───────────────────────────────────────────────────────────────
LOG_LEVEL=info
RATE_LIMIT_MAX=20          # max requests per window per IP
RATE_LIMIT_WINDOW=60000    # window in ms (60s)
MAX_PGN_PLIES=300
MAX_PGN_BYTES=524288       # 512 KB

# ── Analyze Service ───────────────────────────────────────────────────────────
STOCKFISH_PATH=/usr/local/bin/stockfish
WORKER_CONCURRENCY=4       # Stockfish subprocesses per replica
STREAM_KEY=chess:jobs
CONSUMER_GROUP=analyze-workers
ENGINE_DEPTH=18
ENGINE_MULTIPV=2
PER_MOVE_TIMEOUT_MS=5000   # 5s per move before Stockfish restart
PER_JOB_TIMEOUT_S=300      # 5min per job before marking failed
BOOK_PLIES=10              # skip classification for first N plies

# ── Scaling ───────────────────────────────────────────────────────────────────
ANALYZE_REPLICAS=1         # increase to scale CPU-heavy analysis
ANALYZE_CPU_LIMIT=2.0
ANALYZE_MEM_LIMIT=512M

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_MAX_MEM=256mb
